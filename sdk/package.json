{
  "name": "@kairune/sdk",
  "version": "0.1.1",
  "description": "Official SDK for the Kairune trust & spend layer for AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["kairune", "ai-agents", "trust", "spend", "enforcement", "virtuals"],
  "author": "Kairune <dev@kairune.online>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kairunedev/Kairune"
  },
  "homepage": "https://kairune.online",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
