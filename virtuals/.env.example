# Copy to .env — NEVER commit real .env

# From Virtuals agent page → Signers / wallet
ACP_WALLET_ADDRESS=0xYourAgentWallet
ACP_WALLET_ID=wallet-id-from-virtuals
ACP_SIGNER_PRIVATE_KEY=0xYourSignerPrivateKey

# Optional — Settings tab on agent page
# ACP_BUILDER_CODE=bc-...

# Kairune API (default production)
KAIRUNE_API_BASE=https://kairune.online/api
