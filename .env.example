# Kairune server configuration
# Copy to .env and adjust. NEVER commit the real .env.

# HTTP port the server listens on (default: 3040)
PORT=3040

# Host bind address (default: 0.0.0.0 = all interfaces)
HOST=0.0.0.0

# Environment: development | production
NODE_ENV=production

# --- Database ---
# LOCAL (default): use a SQLite file. Leave the Turso vars empty.
DB_PATH=./data/kairune.db

# PRODUCTION / VERCEL: set both to use Turso (SQLite cloud).
# If TURSO_DATABASE_URL is set, DB_PATH is ignored.
# Get them via: turso db show kairune --url  &&  turso db tokens create kairune
# TURSO_DATABASE_URL=libsql://kairune-xxx.turso.io
# TURSO_AUTH_TOKEN=your-token-here

# --- Rate limiting (mutating endpoints only: POST/PATCH/DELETE) ---
# Reads (GET) are never limited. Defaults are sensible; override if needed.
# RATE_LIMIT_WINDOW_MS=60000   # window size in ms
# RATE_LIMIT_MAX=40            # max writes per window per IP
# RATE_LIMIT_DISABLED=1        # set to 1 to turn limiting off entirely

# --- Soft $KAIRUNE utility (no chain RPC) ---
# Comma-separated holder wallets get a higher write rate limit.
# TOKEN_HOLDER_WALLETS=0xabc...,0xdef...
# TOKEN_HOLDER_RATE_MAX=120

# Ephemeral demo agents (try-* / demo-loop) auto-delete after N hours (default 6).
# DEMO_TTL_HOURS=6

# --- Admin moderation ---
# When set, DELETE /api/agents/:id and issuer registration require X-Admin-Key.
# ADMIN_KEY=

# --- Verifiable attestations ---
# Weight applied to UNVERIFIED (unsigned) attestations in the trust score.
# Verified (signed) attestations always count at 1.0. Range 0.0-1.0, default 0.25.
# UNVERIFIED_WEIGHT_FACTOR=0.25
